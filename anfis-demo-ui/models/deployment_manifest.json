{
  "version": "2.2",
  "status": "PRODUCTION",
  "export_date": "2026-05-06T20:30:00+05:30",
  "pipeline": {
    "features": [
      "enemiesHit",
      "damageDone",
      "timeInCombat",
      "kills",
      "itemsCollected",
      "pickupAttempts",
      "timeNearInteractables",
      "distanceTraveled",
      "timeSprinting",
      "timeOutOfCombat",
      "damage_per_hit",
      "pickup_attempt_rate"
    ],
    "num_features": 12,
    "k_clusters": 3,
    "anfis_architecture": "6-16-8-1",
    "training_samples": 3240
  },
  "artifacts": {
    "scaler": "scaler_params.json",
    "centroids": "cluster_centroids.json",
    "mlp_model": "anfis_mlp_weights.json",
    "stats": "training_stats.json"
  },
  "hard_constraints": {
    "duration_min_minutes": 20,
    "duration_cap_minutes": 45,
    "target_multiplier_range": [
      0.6,
      1.4
    ],
    "archetype_modifier_range": [
      0.85,
      1.15
    ]
  },
  "feature_calculations": {
    "derived": {
      "damage_per_hit": "damageDone_raw / max(enemiesHit_raw, 1)",
      "pickup_attempt_rate": "pickupAttempts_raw / max(timeNearInteractables_raw, 1)"
    },
    "pct_combat": "(enemiesHit + damageDone + timeInCombat + kills + damage_per_hit) / 5",
    "pct_collect": "(itemsCollected + pickupAttempts + timeNearInteractables + pickup_attempt_rate) / 4",
    "pct_explore": "(distanceTraveled + timeSprinting) / 4"
  },
  "session": {
    "timeout_ms": 90000,
    "window_cadence_s": 30
  },
  "sensitivity_registry": {
    "enemy_health": 0.2,
    "enemy_damage": 0.25,
    "spawn_rate": 0.35,
    "spawn_delay": 0.3,
    "default": 0.3
  }
}